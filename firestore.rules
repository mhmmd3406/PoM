rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.is_admin == true;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isCompanyAdmin() {
      return isAuthenticated() && request.auth.token.company_admin == true;
    }
    function isCompanyMember(companyId) {
      return isAuthenticated() && request.auth.token.company_id == companyId;
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Check-ins
    match /checkins/{checkinId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Platform config (thresholds etc.) — admin write, authenticated read
    match /platform_config/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Insights (aggregated, written by Cloud Functions via Admin SDK)
    match /insights/{insightId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Cloud Functions only (admin SDK bypasses rules)
    }

    // Wallets — read/write via Cloud Functions only
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // Subscriptions — read own, write via Cloud Functions only
    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // DaaS API keys — read own, write via Cloud Functions only
    match /daas_api_keys/{keyId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Cloud Functions only
    }

    // Surveys — admins manage all; company admins manage their company's;
    // all authenticated users read surveys for their company OR platform-wide ('__admin__') ones.
    match /surveys/{surveyId} {
      allow read: if isAdmin()
        || (isAuthenticated() && (
               resource.data.companyId == '__admin__'
            || isCompanyMember(resource.data.companyId)
           ));
      allow create: if isAdmin()
        || (isCompanyAdmin() && isCompanyMember(request.resource.data.companyId));
      allow update, delete: if isAdmin()
        || (isCompanyAdmin() && isCompanyMember(resource.data.companyId));
    }

    // Survey responses — admins and company admins read all for their company;
    // any authenticated user can submit and read their company's responses.
    match /survey_responses/{responseId} {
      allow read: if isAdmin()
        || (isAuthenticated() && (
               resource.data.companyId == '__admin__'
            || isCompanyMember(resource.data.companyId)
           ));
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Admin catch-all: full access to any unmatched document
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
