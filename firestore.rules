rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ─────────────────────────────────────────────────────────────
    function isAuthenticated() { return request.auth != null; }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.is_admin == true;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isCompanyAdmin() {
      return isAuthenticated() && request.auth.token.company_admin == true;
    }
    function isCompanyMember(companyId) {
      return isAuthenticated() && request.auth.token.company_id == companyId;
    }

    // ── users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── checkins ─────────────────────────────────────────────────────────────
    match /checkins/{checkinId} {
      allow read:   if isAuthenticated()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── platform config ──────────────────────────────────────────────────────
    match /platform_config/{doc} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── companies ────────────────────────────────────────────────────────────
    match /companies/{companyId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── benchmarks (read-only reference data) ────────────────────────────────
    match /benchmarks/{doc} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── insights (Cloud Functions only) ──────────────────────────────────────
    match /insights/{insightId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── wallets (Cloud Functions only) ───────────────────────────────────────
    match /wallets/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ── subscriptions (Cloud Functions only) ─────────────────────────────────
    match /subscriptions/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ── transactions (Cloud Functions only) ──────────────────────────────────
    match /transactions/{transactionId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── DaaS API keys (Cloud Functions only) ─────────────────────────────────
    match /daas_api_keys/{keyId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── surveys ──────────────────────────────────────────────────────────────
    // read  → herhangi authenticated kullanıcı
    // create/delete → is_admin VEYA kendi şirketinin company_admin'i
    // update:
    //   • is_admin  → tam erişim
    //   • company_admin kendi şirketinde → tam erişim
    //   • herhangi authed kullanıcı → SADECE responseCount'u +1 artırabilir
    match /surveys/{surveyId} {
      allow read: if isAuthenticated();

      allow create: if isAdmin()
        || (isCompanyAdmin() && isCompanyMember(request.resource.data.companyId));

      allow update: if isAdmin()
        || (isCompanyAdmin() && isCompanyMember(resource.data.companyId))
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['responseCount'])
            && request.resource.data.responseCount
                 == resource.data.responseCount + 1);

      allow delete: if isAdmin()
        || (isCompanyAdmin() && isCompanyMember(resource.data.companyId));
    }

    // ── survey responses ─────────────────────────────────────────────────────
    // Pseudonymous response docs (userIdHash + answers, no PII).
    // create → herhangi authenticated kullanıcı (kendi yanıtını yazar)
    // read   → is_admin VEYA aynı şirketin üyesi (company_id claim eşleşmesi)
    //   NOT: Mobil artık survey_responses OKUMUYOR. "Zaten cevaplandı" bilgisi
    //   kullanıcının kendi users/{uid}.answeredSurveyIds alanında tutulur (yalnız
    //   sahibe açık), böylece read'i şirkete bağlamak mobil akışı bozmadan
    //   şirketler-arası okumayı kapatır. Şirket paneli (company_admin) yanıtları
    //   okurken sorgusunu `where companyId == <kendi şirketi>` ile kısıtlamalı —
    //   Firestore kuralları filtre DEĞİLDİR, sorgu kısıtı kuralı karşılamalı.
    // update/delete → is_admin only
    match /survey_responses/{responseId} {
      allow read:   if isAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ── admin catch-all ──────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
