rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ─────────────────────────────────────────────────────────────
    function isAuthenticated() { return request.auth != null; }
    function isAdmin() {
      // is_admin custom claim VEYA admins/{uid} dokümanı (token-refresh gerektirmez)
      return isAuthenticated() && (
        request.auth.token.is_admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isCompanyAdmin() {
      return isAuthenticated() && request.auth.token.company_admin == true;
    }
    function isCompanyMember(companyId) {
      return isAuthenticated() && request.auth.token.company_id == companyId;
    }
    // The caller's own pseudonymous userIdHash, read from their user doc. Used to
    // bridge owner access to anonymous check-ins/insights (which carry no uid).
    // Only call after isAuthenticated() so request.auth.uid is non-null.
    function myUserIdHash() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userIdHash;
    }
    // The caller's own companyId, read from their user doc. Mobile users carry
    // companyId on the user doc (not as a token claim), so survey_aggregates
    // access is bridged via get() rather than the company_id claim.
    function myCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    // ── users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── checkins ─────────────────────────────────────────────────────────────
    // Anonymous: docs carry no raw uid, only a pseudonymous userIdHash. Owner
    // access is bridged by comparing the caller's own users/{uid}.userIdHash to
    // the doc's userIdHash via get(). The client MUST query with
    // .where('userIdHash','==', myHash) so the query satisfies the rule.
    match /checkins/{checkinId} {
      allow read:   if isAuthenticated()
                    && (isAdmin() || resource.data.userIdHash == myUserIdHash());
      allow create: if isAuthenticated()
                    && request.resource.data.userIdHash == myUserIdHash();
      allow update, delete: if isAdmin();
    }

    // ── platform config ──────────────────────────────────────────────────────
    match /platform_config/{doc} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── companies ────────────────────────────────────────────────────────────
    match /companies/{companyId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── benchmarks (read-only reference data) ────────────────────────────────
    match /benchmarks/{doc} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── insights (Cloud Functions only) ──────────────────────────────────────
    // Keyed by the pseudonymous userIdHash (no raw uid). Owner read is bridged
    // the same way as check-ins.
    match /insights/{insightId} {
      allow read: if isAuthenticated()
                  && (isAdmin() || resource.data.userIdHash == myUserIdHash());
      allow write: if false;
    }

    // ── wallets (Cloud Functions only) ───────────────────────────────────────
    match /wallets/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ── subscriptions (Cloud Functions only) ─────────────────────────────────
    match /subscriptions/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ── transactions (Cloud Functions only) ──────────────────────────────────
    match /transactions/{transactionId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── DaaS API keys (Cloud Functions only) ─────────────────────────────────
    match /daas_api_keys/{keyId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── surveys ──────────────────────────────────────────────────────────────
    // read  → herhangi authenticated kullanıcı
    // create/delete → is_admin VEYA kendi şirketinin company_admin'i
    // update:
    //   • is_admin  → tam erişim
    //   • company_admin kendi şirketinde → tam erişim
    //   • herhangi authed kullanıcı → SADECE responseCount'u +1 artırabilir
    match /surveys/{surveyId} {
      allow read: if isAuthenticated();

      allow create: if isAdmin()
        || (isCompanyAdmin() && isCompanyMember(request.resource.data.companyId));

      allow update: if isAdmin()
        || (isCompanyAdmin() && isCompanyMember(resource.data.companyId))
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['responseCount'])
            && request.resource.data.responseCount
                 == resource.data.responseCount + 1);

      allow delete: if isAdmin()
        || (isCompanyAdmin() && isCompanyMember(resource.data.companyId));
    }

    // ── survey responses ─────────────────────────────────────────────────────
    // Pseudonymous response docs (userIdHash + answers, no PII).
    // create → authenticated kullanıcı, AMA sıkı şekil + şirket bütünlüğü ile:
    //   • Sadece beklenen alanlar yazılabilir (fazladan alan enjeksiyonu yok).
    //   • Yanıtın companyId'si, cevapladığı survey'in companyId'si ile birebir
    //     eşleşmeli (referans verilen survey gerçekten var olmalı). Böylece bir
    //     kullanıcı yanıtı keyfi/başka bir şirkete etiketleyip o şirketin veri
    //     havuzunu sabote edemez. Mobil zaten companyId: survey.companyId yazıyor
    //     (platform anketlerinde her iki tarafta da '__admin__'), o yüzden bu
    //     kural meşru akışı bozmaz; yalnızca kötü niyetli istemciyi engeller.
    //   NOT (eksik kalan koruma): Kullanıcı başına TEK yanıt ve userIdHash'in
    //     çağırana ait olduğunun doğrulanması kural katmanında yapılamaz (rules
    //     sha256 hesaplayamaz, doc'ta uid yok). Tam koruma için yanıt yazımı bir
    //     callable Cloud Function'a taşınmalı (hash'i request.auth.uid'den türetip
    //     mükerrer yanıtı engeller; create: if false yapılır). Ayrı PR önerilir.
    // read   → is_admin VEYA aynı şirketin üyesi (company_id claim eşleşmesi).
    //   Mobil artık survey_responses OKUMUYOR; "zaten cevaplandı" bilgisi
    //   users/{uid}.answeredSurveyIds'te tutulur (yalnız sahibe açık).
    // update/delete → is_admin only
    match /survey_responses/{responseId} {
      allow read:   if isAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly(
             ['surveyId', 'companyId', 'userIdHash', 'answers', 'created_at'])
        && request.resource.data.surveyId is string
        && request.resource.data.companyId is string
        && request.resource.data.userIdHash is string
        && request.resource.data.answers is map
        && exists(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId))
        && get(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.companyId
             == request.resource.data.companyId;
      allow update, delete: if isAdmin();
    }

    // ── survey_aggregates (Cloud Functions only) ──────────────────────────────
    // computeSurveyAggregate yazar; min-N korumalı, anonim grup ortalamaları.
    // Doc id = '{surveyId}__{companyId}'. read → o şirketin üyesi (kullanıcının
    // user doc'undaki companyId) VEYA admin. Bir şirket başka şirketin skorunu
    // GÖREMEZ; sektör bloğu doc içinde denormalize (anonim cross-company benchmark).
    match /survey_aggregates/{aggId} {
      allow read:  if isAdmin() || (isAuthenticated()
                       && resource.data.companyId == myCompanyId());
      allow write: if false; // yalnız Cloud Functions (Admin SDK kuralları bypass eder)
    }

    // ── platform yönetim koleksiyonları (admin panel) ─────────────────────────
    // NOT: feature_flags ve legal_texts, platform_config/{doc} altında saklanır;
    // o koleksiyon yukarıda zaten read: authenticated / write: isAdmin() ile korunur.

    // banks → referans veri: app okur, yalnız admin yazar (companies/benchmarks ile aynı desen)
    match /banks/{bankId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // announcements → uygulama içi banner: app okur, yalnız admin yazar
    match /announcements/{announcementId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // disputes → hassas: yalnız admin okur/yazar.
    // (Banka/B2B itiraz gönderimi sunucu-taraflı bir Cloud Function ile yapılır.)
    match /disputes/{disputeId} {
      allow read, write: if isAdmin();
    }

    // ── admin catch-all ──────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
