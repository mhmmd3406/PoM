{
  "name": "pom-functions",
  "description": "PoM Cloud Functions",
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test test/thresholds.test.cjs",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": { "node": "20" },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.0",
    "stripe": "^17.3.1",
    "axios": "^1.7.7",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "private": true
}
