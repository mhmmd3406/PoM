# NON-SECRET config — safe to commit, set via Firebase environment
# firebase functions:config:set linkedin.client_id="..." linkedin.redirect_uri="..."
LINKEDIN_CLIENT_ID=your_linkedin_app_client_id
LINKEDIN_REDIRECT_URI=https://REGION-PROJECT_ID.cloudfunctions.net/linkedinCallback

# -----------------------------------------------------------------------
# SECRETS — DO NOT commit values. Use Google Cloud Secret Manager:
#
#   firebase functions:secrets:set LINKEDIN_CLIENT_SECRET
#   firebase functions:secrets:set LINKEDIN_ID_SALT        # random 64-char hex
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
#
# Generate a strong salt:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------
