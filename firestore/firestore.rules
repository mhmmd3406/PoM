rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // RBAC helpers — subscription_tier is a Firebase custom claim set by
    // Cloud Function triggers whenever the users/{uid} document changes.
    // Tiers in ascending privilege order:
    //   free → pro → standard → professional → enterprise → daas
    // -----------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function tier() {
      return request.auth.token.get('subscription_tier', 'free');
    }

    function isAtLeastPro() {
      return tier() in ['pro', 'standard', 'professional', 'enterprise', 'daas'];
    }

    function isAtLeastEnterprise() {
      return tier() in ['enterprise', 'daas'];
    }

    function isB2BUser() {
      return isAuthenticated()
          && request.auth.token.get('b2b_bank_id', null) != null;
    }

    // Privacy gate: document must have N >= 7 entries to be readable
    function meetsPrivacyThreshold(doc) {
      return doc.data.entry_count >= 7;
    }

    function validRating(v) {
      return v is int && v >= 1 && v <= 5;
    }

    function validRatings(ratings) {
      return validRating(ratings.salary)
          && validRating(ratings.benefits)
          && validRating(ratings.work_model)
          && validRating(ratings.culture)
          && validRating(ratings.wlb);
    }

    // -----------------------------------------------------------------------
    // users/{userId}
    // -----------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId);

      // Direct client creates are forbidden — Cloud Function onUserCreated handles this
      allow create: if false;

      // Only mutable profile fields; subscription fields are server-only
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny([
              'linkedin_hash', 'joined_at', 'credits',
              'subscription_tier', 'subscription_status',
              'subscription_expires_at', 'stripe_customer_id', 'api_key'
            ]);

      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // credit_transactions/{txnId}
    // -----------------------------------------------------------------------
    match /credit_transactions/{txnId} {
      allow read: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // banks/{bankId}
    // -----------------------------------------------------------------------
    match /banks/{bankId} {
      allow read: if isAuthenticated() && resource.data.is_active == true;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // checkins/{checkinId}
    // Raw check-in data is never readable by clients (privacy by design).
    // -----------------------------------------------------------------------
    match /checkins/{checkinId} {
      allow read: if false;

      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll([
            'user_hash', 'bank_id', 'business_family', 'department_type',
            'seniority_level', 'year', 'month', 'week_number', 'ratings', 'created_at'
          ])
        && validRatings(request.resource.data.ratings)
        && request.resource.data.year is int
        && request.resource.data.month is int
        && request.resource.data.month >= 1
        && request.resource.data.month <= 12;

      allow update, delete: if false;
    }

    // -----------------------------------------------------------------------
    // aggregations/{aggId}
    //
    // RBAC:
    //   Free tier  → overall scores only (business_family == 'all')
    //   Pro+       → any business family breakdown
    //   Enterprise → covered by Pro+ rule; b2b_snapshots for deep access
    // -----------------------------------------------------------------------
    match /aggregations/{aggId} {
      allow read: if isAuthenticated()
        && meetsPrivacyThreshold(resource)
        && (
          // Free users may only read the 'all' rollup — not family breakdowns
          resource.data.business_family == 'all'
          || isAtLeastPro()
        );

      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // sector_aggregations/{aggId}
    // Same RBAC as aggregations — sector-wide but still tiered.
    // -----------------------------------------------------------------------
    match /sector_aggregations/{aggId} {
      allow read: if isAuthenticated()
        && meetsPrivacyThreshold(resource)
        && (
          resource.data.business_family == 'all'
          || isAtLeastPro()
        );

      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // query_sessions/{sessionId}
    // -----------------------------------------------------------------------
    match /query_sessions/{sessionId} {
      allow read: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // b2b_snapshots/{snapId}
    // Enterprise+ B2B users only; bank_id must match their custom claim.
    // The DaaS widget reads this via the Admin SDK (bypasses rules).
    // -----------------------------------------------------------------------
    match /b2b_snapshots/{snapId} {
      allow read: if isB2BUser()
        && isAtLeastEnterprise()
        && resource.data.bank_id == request.auth.token.b2b_bank_id;

      allow write: if false;
    }

    match /b2b_snapshots_archive/{archiveId} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------------
    // b2b_reports/{reportId}
    // Enterprise+ B2B users only.
    // -----------------------------------------------------------------------
    match /b2b_reports/{reportId} {
      allow read: if isB2BUser()
        && isAtLeastEnterprise()
        && resource.data.bank_id == request.auth.token.b2b_bank_id;

      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // api_keys/{keyId}
    // DaaS API keys — readable only by the owner for self-inspection.
    // All writes are server-side via Admin SDK.
    // -----------------------------------------------------------------------
    match /api_keys/{keyId} {
      allow read: if isAuthenticated()
        && resource.data.owner_uid == request.auth.uid;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // Default deny
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
