rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // RBAC helpers
    // -----------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function tier() {
      return request.auth.token.get('subscription_tier', 'free');
    }

    function isAtLeastPro() {
      return tier() in ['pro', 'standard', 'professional', 'enterprise', 'daas'];
    }

    function isAtLeastEnterprise() {
      return tier() in ['enterprise', 'daas'];
    }

    function isB2BUser() {
      return isAuthenticated()
          && request.auth.token.get('b2b_bank_id', null) != null;
    }

    // Hard-floor privacy gate (safety net — application layer enforces higher thresholds).
    // This ensures that even a misconfigured application cannot expose data below N=7.
    function meetsPrivacyFloor(doc) {
      return doc.data.entry_count >= 7;
    }

    function validRating(v) {
      return v is int && v >= 1 && v <= 5;
    }

    function validRatings(ratings) {
      return validRating(ratings.salary)
          && validRating(ratings.benefits)
          && validRating(ratings.work_model)
          && validRating(ratings.culture)
          && validRating(ratings.wlb);
    }

    // -----------------------------------------------------------------------
    // platform_config/{docId}
    // All authenticated users may read (needed by Flutter + B2B dashboard).
    // All writes are server-side via Admin SDK — clients cannot write.
    // -----------------------------------------------------------------------
    match /platform_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // announcements/{announcementId}
    // All authenticated users may read active announcements.
    // -----------------------------------------------------------------------
    match /announcements/{announcementId} {
      allow read: if isAuthenticated() && resource.data.is_active == true;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // disputes/{disputeId}
    // B2B users may create disputes for their own bank.
    // B2B users may read their own bank's disputes.
    // Only admin Cloud Functions may update (via Admin SDK).
    // -----------------------------------------------------------------------
    match /disputes/{disputeId} {
      allow read: if isB2BUser()
        && resource.data.bank_id == request.auth.token.b2b_bank_id;
      allow create: if isB2BUser()
        && request.resource.data.bank_id == request.auth.token.b2b_bank_id
        && request.resource.data.submitted_by == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // -----------------------------------------------------------------------
    // users/{userId}
    // -----------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if false;

      // Mutable profile fields + kvkk consent version.
      // Server-controlled fields are blocked.
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny([
              'linkedin_hash', 'joined_at', 'credits',
              'subscription_tier', 'subscription_status',
              'subscription_expires_at', 'stripe_customer_id', 'api_key'
            ]);

      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // credit_transactions/{txnId}
    // -----------------------------------------------------------------------
    match /credit_transactions/{txnId} {
      allow read: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // banks/{bankId}
    // Active banks readable by authenticated users.
    // Writes are admin-only (via Admin SDK / Cloud Functions).
    // -----------------------------------------------------------------------
    match /banks/{bankId} {
      allow read: if isAuthenticated() && resource.data.is_active == true;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // checkins/{checkinId}
    // -----------------------------------------------------------------------
    match /checkins/{checkinId} {
      allow read: if false;

      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll([
            'user_hash', 'bank_id', 'business_family', 'department_type',
            'seniority_level', 'year', 'month', 'week_number', 'ratings', 'created_at'
          ])
        && validRatings(request.resource.data.ratings)
        && request.resource.data.year is int
        && request.resource.data.month is int
        && request.resource.data.month >= 1
        && request.resource.data.month <= 12;

      allow update, delete: if false;
    }

    // -----------------------------------------------------------------------
    // aggregations/{aggId}
    // Hard-floor N>=7 enforced here. Application layer uses higher thresholds
    // from platform_config (N>=15 company, N>=10 department by default).
    // -----------------------------------------------------------------------
    match /aggregations/{aggId} {
      allow read: if isAuthenticated()
        && meetsPrivacyFloor(resource)
        && (
          resource.data.business_family == 'all'
          || isAtLeastPro()
        );

      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // sector_aggregations/{aggId}
    // -----------------------------------------------------------------------
    match /sector_aggregations/{aggId} {
      allow read: if isAuthenticated()
        && meetsPrivacyFloor(resource)
        && (
          resource.data.business_family == 'all'
          || isAtLeastPro()
        );

      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // query_sessions/{sessionId}
    // -----------------------------------------------------------------------
    match /query_sessions/{sessionId} {
      allow read: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // b2b_snapshots/{snapId}
    // -----------------------------------------------------------------------
    match /b2b_snapshots/{snapId} {
      allow read: if isB2BUser()
        && isAtLeastEnterprise()
        && resource.data.bank_id == request.auth.token.b2b_bank_id;

      allow write: if false;
    }

    match /b2b_snapshots_archive/{archiveId} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------------
    // b2b_reports/{reportId}
    // -----------------------------------------------------------------------
    match /b2b_reports/{reportId} {
      allow read: if isB2BUser()
        && isAtLeastEnterprise()
        && resource.data.bank_id == request.auth.token.b2b_bank_id;

      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // api_keys/{keyId}
    // -----------------------------------------------------------------------
    match /api_keys/{keyId} {
      allow read: if isAuthenticated()
        && resource.data.owner_uid == request.auth.uid;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // Default deny
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
